// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String           @id @default(cuid())
  googleId         String?          @unique @map("google_id")
  name             String?
  email            String           @unique
  password         String
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  moods            Mood[]
  executions       Execution[]
  journalings      Journaling[]
  copingStrategies CopingStrategy[]
  peerStories      PeerStory[]
  storySupports    StorySupport[]
  storyComments    StoryComment[]

  @@map("users")
}

enum MoodType {
  HAPPY
  SAD
  ANXIOUS
  EXCITED
  ANGRY
  CALM
  STRESSED
  NEUTRAL
  GRATEFUL
  LONELY
}

model Journaling {
  id          String    @id   @default(cuid())
  title       String?
  content     String    @db.Text
  isPrivate   Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  moodType    MoodType?
  moodScore   Int?      @db.SmallInt
  tags        String[]  @default([])

  @@index([userId, createdAt])
}

model Execution {
  id         String   @id @default(cuid())
  title      String
  type       String   @default("CONVERSATION")
  chatId     String? 
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  externalId String?
}

model Conversation {
  id        String    @id @default(cuid())
  title     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  messages  Message[]
}

model Message {
  id             String       @id @default(cuid())
  content        String
  role           String
  createdAt      DateTime     @default(now())
  updateAt       DateTime     @updatedAt
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
}

model Mood {
  id        String   @id @default(cuid())
  userId    String
  text      String
  moodType  String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Feedback {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String   @db.Text
  createdAt DateTime @default(now())
}

model CopingStrategy {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  category       String
  title          String
  description    String   @db.Text
  practiceType   String   @default("general")
  steps          String[] @default([])
  duration       Int      @default(10)
  difficulty     String   @default("beginner")
  isSaved        Boolean  @default(false)
  completedCount Int      @default(0)
  rating         Int?
  culturalNote   String?
  createdAt      DateTime @default(now())
  @@index([userId])
}

model PeerStory {
  id           String         @id @default(cuid())
  userId       String
  user         User           @relation(fields: [userId], references: [id])
  title        String
  content      String         @db.Text
  category     String         @default("general")
  tags         String[]       @default([])
  isApproved   Boolean        @default(false)
  isAnonymous  Boolean        @default(true)
  supportCount Int            @default(0)
  createdAt    DateTime       @default(now())
  supports     StorySupport[]
  comments     StoryComment[]

  @@index([userId])
  @@index([category])
}

model StorySupport {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  storyId   String
  story     PeerStory @relation(fields: [storyId], references: [id], onDelete: Cascade)
  type      String    @default("heart")
  createdAt DateTime  @default(now())

  @@unique([userId, storyId])
}

model StoryComment {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  storyId    String
  story      PeerStory @relation(fields: [storyId], references: [id], onDelete: Cascade)
  content    String
  isApproved Boolean   @default(false)
  createdAt  DateTime  @default(now())

  @@index([storyId])
}

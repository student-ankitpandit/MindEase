enum MoodType {
  HAPPY
  SAD
  ANXIOUS
  EXCITED
  ANGRY
  CALM
  STRESSED
  NEUTRAL
  GRATEFUL
  LONELY
}

model Journaling {
  id        String    @id @default(cuid())
  title     String?
  content   String    @db.Text
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  moodType  MoodType?
  moodScore Int?      @db.SmallInt
  tags      String[]  @default([])

  // dashboardId String
  // dashboard   Dashboard @relation(fields: [dashboardId], references: [id])

  @@index([userId, createdAt])
}

model Execution {
  id         String   @id @default(cuid())
  title      String
  type       String   @default("CONVERSATION")
  chatId     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  externalId String? //linked to the conversation.id 
}

model Conversation {
  id        String    @id @default(cuid())
  title     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  messages  Message[]
}

model Message {
  id             String       @id @default(cuid())
  content        String
  role           String
  createdAt      DateTime     @default(now())
  updateAt       DateTime     @updatedAt
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
}

model Mood {
  id        String   @id @default(cuid())
  userId    String
  text      String
  moodType  String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}
